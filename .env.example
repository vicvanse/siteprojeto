# Copie para `.env.local` (não commite ficheiros `.env*` com segredos).

# URL pública do site (metadata, links absolutos)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Links de contacto/redes — opcionais; vazio = o botão ou link não aparece
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_INSTAGRAM_LABEL=
# NEXT_PUBLIC_TIKTOK_URL=
# NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_GOODREADS_URL=
# NEXT_PUBLIC_SPOTIFY_USER_URL=

# --- Sugestões (formulário): configure pelo menos UM destino em produção ---

# Discord: canal → Definições → Integrações → Webhooks → copiar URL
SUGESTOES_DISCORD_WEBHOOK_URL=

# Resend (e-mail) — `SUGESTOES_EMAIL_TO` é obrigatório para enviar e-mail
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# SUGESTOES_EMAIL_TO=

# Upstash Redis (lista na página /sugestoes-inbox?token=...)
# O mesmo Redis aplica um limite de taxa suave em POST /api/sugestoes (por IP).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SUGESTOES_INBOX_TOKEN=
